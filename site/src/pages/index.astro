---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { fmtDate, daysUntil } from '../lib/format';
import signals from '../data/signals.json';

const events = (await getCollection('events')).sort(
  (a, b) => (b.data.deadline ?? b.data.announced).localeCompare(a.data.deadline ?? a.data.announced),
);
// past-deadline guides count as sunk automatically, whatever their frontmatter says
const effectiveStatus = (e) =>
  e.data.deadline && daysUntil(e.data.deadline) < 0 ? 'sunk' : e.data.status;
const sinking = events.filter((e) => effectiveStatus(e) === 'sinking');
const sunk = events.filter((e) => effectiveStatus(e) === 'sunk');
const recentSignals = signals.slice(0, 6);
const buildDate = new Date().toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Base
  title="Lifeboat — survival guides for sinking software"
  description="A live registry of SaaS shutdowns. Deadlines, data-export steps, migration scripts, and the best alternatives — researched while the announcement is still fresh."
>
  <div class="hero">
    <div class="coords">
      REGISTRY OF SOFTWARE WRECKS<br />
      UPDATED {buildDate}<br />
      ALL HANDS · NO PAYWALL
    </div>
    <h1 class="rise">Your software is <em>sinking.</em> We row out anyway.</h1>
    <p class="lede rise d1">
      When a product announces shutdown, its users get a deadline and a shrug. Lifeboat charts the
      way out: what happens to your data, when the lights go off, and which ships are worth
      boarding — with working migration steps, not listicles.
    </p>
  </div>

  {sinking.length > 0 && (
    <section class="rise d2">
      <div class="section-head"><h2><span class="tick">▸</span> Actively sinking</h2></div>
      <ul class="manifest">
        {sinking.map((e) => (
          <li>
            <a class="row" href={`${base}/shutdowns/${e.id}`}>
              <span class="badge sinking">Sinking</span>
              <span>
                <span class="product">{e.data.product}</span>
                <span class="tagline">{e.data.tagline}</span>
              </span>
              <span class="when">
                {e.data.deadline
                  ? `goes dark ${fmtDate(e.data.deadline)} · ${daysUntil(e.data.deadline)}d`
                  : 'date unannounced'}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {sunk.length > 0 && (
    <section>
      <div class="section-head"><h2><span class="tick">▸</span> On the seafloor</h2></div>
      <ul class="manifest">
        {sunk.map((e) => (
          <li>
            <a class="row" href={`${base}/shutdowns/${e.id}`}>
              <span class="badge sunk">Sunk</span>
              <span>
                <span class="product">{e.data.product}</span>
                <span class="tagline">{e.data.tagline}</span>
              </span>
              <span class="when">{e.data.deadline ? `went dark ${fmtDate(e.data.deadline)}` : ''}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="rise d3">
    <div class="section-head"><h2><span class="tick">▸</span> Fresh distress signals</h2></div>
    <p class="notice">
      Raw automated detections from our 24/7 watcher — unverified until a guide ships.
      Full feed on the <a href={`${base}/signals`}>signals page</a>.
    </p>
    <table class="signals">
      <tbody>
        {recentSignals.map((s) => (
          <tr>
            <td class="score">{s.score}</td>
            <td><a href={s.url} rel="noopener">{s.title}</a></td>
            <td class="src">{s.source}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</Base>
